{
  "name": "design-trends-prompt-appender",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && esbuild src/plugin-code.ts --bundle --outfile=dist/code.js --target=es2017",
    "build:ui": "vite build",
    "build:code": "esbuild src/plugin-code.ts --bundle --outfile=dist/code.js --target=es2017",
    "export-prompts": "esbuild scripts/export-prompts.ts --bundle --platform=node --format=esm --outfile=scripts/export-prompts.mjs && node scripts/export-prompts.mjs",
    "watch": "concurrently \"vite build --watch\" \"esbuild src/plugin-code.ts --bundle --outfile=dist/code.js --watch --target=es2017\""
  },
  "dependencies": {
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.3",
    "tw-animate-css": "^1.3.8"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.128.0",
    "@tailwindcss/vite": "^4.1.12",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.2",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
